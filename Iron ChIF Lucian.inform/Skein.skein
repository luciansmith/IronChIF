    <command xml:space="preserve">wear cloak</command>
    <result xml:space="preserve">(the purple hunting cloak)&#x000A;You put on the purple hunting cloak.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
    <children>
      <child nodeId="node-901"/>
    </children>
  </item>
