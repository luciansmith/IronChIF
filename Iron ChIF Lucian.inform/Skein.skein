    </children>
  </item>
  <item nodeId="node-1082">
    <command xml:space="preserve">showme cloak</command>
    <result xml:space="preserve">(the invisible hunting cloak)&#x000A;invisible hunting cloak - thing&#x000A;location: on the two cloak posts in Lower Great Hall&#x000A;unlit, inedible, portable, wearable; singular-named, improper-named; invisible&#x000A;description: "The cloak posts appear to be empty."&#x000A;initial appearance: none&#x000A;printed name: "invisible hunting cloak"&#x000A;printed plural name: none&#x000A;indefinite article: none&#x000A;list grouping key: none&#x000A;&#x000A;&gt;</result>
