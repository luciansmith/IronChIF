  <item nodeId="node-280">
    <command xml:space="preserve">u</command>
    <result xml:space="preserve">You're already high enough to avoid being seen from below; there's no need to go higher.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
    <children>
