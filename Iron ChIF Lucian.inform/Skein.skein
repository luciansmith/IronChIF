  <item nodeId="node-712">
    <command xml:space="preserve">showme blue capsa</command>
    <result xml:space="preserve">blue capsa of mist - capsa&#x000A;    scroll of bostrat - scroll&#x000A;location: in the leather rucksack carried by yourself in Lower Great Hall&#x000A;unlit, inedible, portable, handled; opaque, closed, openable, unlocked; singular-named, improper-named&#x000A;description: "You suppose that now that the scroll's power has been spread to Bostrat everywhere, that capsa itself is little more than a trinket; a curiosity.  But you can't help but think of it almost reverentially.  In a very real sense, it made you.  A part of you."&#x000A;initial appearance: none&#x000A;carrying capacity: 100&#x000A;printed name: "blue capsa of mist"&#x000A;printed plural name: "capsae"&#x000A;indefinite article: none&#x000A;list grouping key: none&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
    <children>
      <child nodeId="node-713"/>
    </children>
  </item>
