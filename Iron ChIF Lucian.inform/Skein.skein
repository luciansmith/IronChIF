    </children>
  </item>
  <item nodeId="node-904">
    <command xml:space="preserve">open opening</command>
    <result xml:space="preserve">(the purple capsa of opening)&#x000A;That's already open.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
