  <item nodeId="node-711">
    <command xml:space="preserve">showme rucksack</command>
    <result xml:space="preserve">leather rucksack - player's holdall&#x000A;    blue capsa of mist - capsa&#x000A;        scroll of bostrat - scroll&#x000A;    red capsa of hasten - capsa&#x000A;        scroll of quiste - scroll&#x000A;    purple capsa of opening - capsa&#x000A;        scroll of rezrov - scroll&#x000A;    gold capsa of down - capsa&#x000A;        scroll of rudenj - scroll&#x000A;location: carried by yourself in Lower Great Hall&#x000A;unlit, inedible, portable, wearable, handled; opaque, open, openable, unlocked; singular-named, improper-named&#x000A;description: none&#x000A;initial appearance: none&#x000A;carrying capacity: 100&#x000A;printed name: "leather rucksack"&#x000A;printed plural name: "player's holdalls"&#x000A;indefinite article: none&#x000A;list grouping key: none&#x000A;&#x000A;&gt;</result>
