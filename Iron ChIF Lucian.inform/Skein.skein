  <item nodeId="node-160">
    <command xml:space="preserve">get rezrov from purple</command>
    <result xml:space="preserve">Like all of the Ancient Scrolls, the scroll is inextricably tied to its capsa&#x000A;Taken.&#x000A;&#x000A;&gt;</result>
