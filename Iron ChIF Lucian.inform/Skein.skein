    <changed>NO</changed>
  </item>
  <item nodeId="node-882">
    <command xml:space="preserve">x posts</command>
    <result xml:space="preserve">Two posts for displaying cloaks.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
    <children>
      <child nodeId="node-883"/>
    </children>
  </item>
  <item nodeId="node-883">
    <command xml:space="preserve">get cloak</command>
    <result xml:space="preserve">(the hunting cloak)&#x000A;You reach for the post, and feel the cloak you saw.  With a sense of wonderment, you pick it up.  Next to you, Horatio picks up the other, equally-invisible cloak.&#x000A;&#x000A;Your wound aches.  You look down at it, and it's still open and a fast small trickle of blood drips down your side.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
    <children>
      <child nodeId="node-884"/>
    </children>
  </item>
